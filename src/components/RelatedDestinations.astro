---
const { links, lang = 'es' } = Astro.props;
const base = import.meta.env.BASE_URL;
const headings: Record<string, string> = {
  es: 'Continúa el viaje',
  en: 'Continue the journey',
  it: 'Continua il viaggio',
  fr: 'Continuez le voyage',
  pt: 'Continue a viagem',
};
const heading = headings[lang] ?? 'Continúa el viaje';
---

<section class="border-t border-hueso mt-12 pt-8">
  <h2 class="text-2xl font-display font-bold mb-6 text-tinta">{heading}</h2>
  <div class="grid md:grid-cols-2 gap-4">
    {links.map(link => (
      <a href={`${base}${link.href.replace(/^\//, '')}`} class="card-hover rounded-lg p-5 block border">
        <h3 class="font-display font-bold text-tinta mb-1">{link.title}</h3>
        <p class="text-sm text-sepia">{link.description}</p>
      </a>
    ))}
  </div>
</section>
