---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../data/i18n.js';
const lang = 'fr';
---
<Base lang={lang} title="Contact — Réservez votre visite" description="Réservez votre visite. María Victoria Solaz." path="/contact/">
  <article class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Contact</h1>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <h2 class="text-xl font-bold mb-4">WhatsApp (recommandé)</h2>
        <a href={`https://wa.me/${SITE.whatsapp.replace('+','')}`} target="_blank" rel="noopener" class="inline-block btn-whatsapp px-8 py-3 rounded-lg text-lg font-medium">💬 Ouvrir WhatsApp</a>
      </div>
      <div>
        <h2 class="text-xl font-bold mb-4">Formulaire</h2>
        <form action="https://formspree.io/f/FORMSPREE_ID" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-sepia mb-1">Nom</label>
            <input id="name" type="text" name="name" placeholder="Votre nom" required class="w-full border border-gray-300 rounded px-4 py-2" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-sepia mb-1">Email</label>
            <input id="email" type="email" name="email" placeholder="vous@email.com" required class="w-full border border-gray-300 rounded px-4 py-2" />
          </div>
          <fieldset>
            <legend class="block text-sm font-medium text-sepia mb-2">Destinations (vous pouvez en choisir plusieurs)</legend>
            <div class="space-y-2">
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="escorial" class="rounded" /> Monastère de l'Escorial</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="avila" class="rounded" /> Ávila</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="segovia" class="rounded" /> Ségovie</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="cuelgamuros" class="rounded" /> Cuelgamuros</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-habsbourg" class="rounded" /> Madrid des Habsbourg</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-bourbons" class="rounded" /> Madrid des Bourbons</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-tour" class="rounded" /> Madrid — Visite personnalisée</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="other" class="rounded" /> Autre (précisez ci-dessous)</label>
            </div>
            <input type="text" name="other_destination" placeholder="Autre destination — laquelle ?" class="w-full mt-3 border border-gray-300 rounded px-4 py-2" />
          </fieldset>
          <div>
            <label for="message" class="block text-sm font-medium text-sepia mb-1">Message</label>
            <textarea id="message" name="message" placeholder="Votre message" rows="4" class="w-full border border-gray-300 rounded px-4 py-2"></textarea>
          </div>
          <button type="submit" class="btn-primary px-6 py-2 rounded">Envoyer</button>
        </form>
      </div>
    </div>
  </article>
</Base>
