---
import { SITE } from '../../data/i18n.js';

const lang = 'fr';
const wa = SITE.whatsapp.replace('+', '');
const base = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.guideName,
  "description": "Visites théâtralisées du Monastère de l'Escorial et des grands monuments de Castille",
  "priceRange": "€€",
  "areaServed": [
    { "@type": "City", "name": "San Lorenzo de El Escorial" },
    { "@type": "City", "name": "Ávila" },
    { "@type": "City", "name": "Ségovie" },
    { "@type": "City", "name": "Madrid" },
    { "@type": "Place", "name": "Cuelgamuros" }
  ],
  "knowsLanguage": ["es", "en", "it", "fr", "pt"],
  "telephone": SITE.whatsapp,
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>María Victoria Solaz · Guide officielle de l'Escorial</title>
  <meta name="description" content="Visites théâtralisées du Monastère de l'Escorial et des grands monuments de Castille. Philippe II comme vous ne l'avez jamais entendu." />
  <link rel="canonical" href={`${SITE.domain}/fr/`} />
  <link rel="alternate" hreflang="es" href={`${SITE.domain}/es/`} />
  <link rel="alternate" hreflang="en" href={`${SITE.domain}/en/`} />
  <link rel="alternate" hreflang="it" href={`${SITE.domain}/it/`} />
  <link rel="alternate" hreflang="fr" href={`${SITE.domain}/fr/`} />
  <link rel="alternate" hreflang="pt" href={`${SITE.domain}/pt/`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE.domain}/en/`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <style>
    :root {
      --cream:       #f4efe3;
      --cream-dark:  #ede5d0;
      --green:       #2a4a2a;
      --green-light: #3a6b3a;
      --gold:        #c4963a;
      --gold-light:  #e8c06a;
      --wine:        #6b1f2a;
      --text:        #2a2118;
      --text-muted:  #7a6a54;
      --white:       #fdfaf4;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--cream); color: var(--text); font-family: 'Lato', sans-serif; font-weight: 300; line-height: 1.6; }
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(244,239,227,0.95); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(196,150,58,0.2); display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 64px; }
    .nav-logo { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 600; color: var(--text); letter-spacing: 0.02em; text-decoration: none; }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { text-decoration: none; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); transition: color 0.2s; }
    .nav-links a:hover { color: var(--wine); }
    .nav-right { display: flex; align-items: center; gap: 20px; }
    .nav-langs { display: flex; gap: 6px; font-size: 12px; letter-spacing: 0.06em; }
    .nav-langs a { text-decoration: none; color: var(--text-muted); padding: 2px 5px; border-radius: 2px; transition: all 0.2s; }
    .nav-langs a.active { color: var(--gold); border-bottom: 1px solid var(--gold); }
    .nav-langs a:hover { color: var(--gold); }
    .btn-primary { background: var(--green); color: var(--white); border: none; padding: 10px 22px; font-family: 'Lato', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; text-decoration: none; display: inline-block; transition: background 0.2s, transform 0.15s; border-radius: 2px; }
    .btn-primary:hover { background: var(--green-light); transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,0.6); padding: 10px 22px; font-family: 'Lato', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; text-decoration: none; display: inline-block; transition: all 0.2s; border-radius: 2px; }
    .btn-ghost:hover { background: rgba(255,255,255,0.15); }
    .hero { margin-top: 64px; position: relative; height: 92vh; min-height: 600px; display: flex; align-items: flex-end; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
    .hero-content { position: relative; z-index: 2; width: 100%; padding: 0 80px 72px; display: grid; grid-template-columns: 1fr auto; align-items: flex-end; gap: 48px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(196,150,58,0.2); border: 1px solid rgba(196,150,58,0.4); color: var(--gold-light); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 14px; border-radius: 2px; margin-bottom: 20px; }
    .hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--gold-light); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
    .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(36px, 5vw, 68px); font-weight: 700; color: var(--white); line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 16px; max-width: 700px; }
    .hero h1 em { font-style: italic; color: var(--gold-light); }
    .hero-sub { color: rgba(255,255,255,0.75); font-size: 18px; font-weight: 300; margin-bottom: 36px; max-width: 520px; }
    .hero-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
    .hero-proof { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.55); font-size: 13px; margin-top: 20px; }
    .stars { color: var(--gold-light); font-size: 14px; letter-spacing: 1px; }
    .urgency-box { background: rgba(20,15,10,0.6); border: 1px solid rgba(196,150,58,0.35); backdrop-filter: blur(12px); border-radius: 4px; padding: 20px 24px; min-width: 240px; }
    .urgency-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-light); margin-bottom: 10px; }
    .urgency-date { font-family: 'Playfair Display', serif; font-size: 17px; color: var(--white); margin-bottom: 6px; }
    .urgency-spots { display: flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.7); margin-bottom: 16px; }
    .spot-dots { display: flex; gap: 3px; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold-light); }
    .dot.taken { background: rgba(255,255,255,0.2); }
    .trust-bar { background: var(--green); padding: 18px 80px; display: flex; align-items: center; justify-content: space-between; gap: 32px; }
    .trust-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.85); font-size: 13px; letter-spacing: 0.04em; }
    .trust-item strong { color: var(--gold-light); font-weight: 700; }
    .trust-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.15); }
    section { padding: 80px; }
    .section-label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
    .section-title { font-family: 'Playfair Display', serif; font-size: clamp(28px, 3vw, 42px); font-weight: 600; color: var(--wine); line-height: 1.2; margin-bottom: 12px; }
    .section-sub { color: var(--text-muted); font-size: 16px; max-width: 560px; line-height: 1.7; }
    .guide-section { background: var(--white); display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 0; overflow: hidden; }
    .guide-image { background-size: cover; background-position: center top; min-height: 520px; position: relative; }
    .guide-image-overlay { position: absolute; inset: 0; background: linear-gradient(to right, transparent 60%, var(--white)); }
    .guide-text { padding: 72px 64px 72px 48px; display: flex; flex-direction: column; justify-content: center; }
    .guide-credentials { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
    .cred-tag { background: var(--cream); border: 1px solid var(--cream-dark); color: var(--text-muted); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; padding: 5px 10px; border-radius: 2px; }
    .guide-text blockquote { font-family: 'Playfair Display', serif; font-size: 22px; font-style: italic; color: var(--wine); line-height: 1.5; margin-bottom: 20px; border-left: 2px solid var(--gold); padding-left: 20px; }
    .guide-text p { color: var(--text-muted); margin-bottom: 28px; line-height: 1.8; }
    .tours-section { background: var(--cream); }
    .tours-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; }
    .tours-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
    .tour-card { background: var(--white); padding: 36px 32px; display: flex; flex-direction: column; position: relative; transition: transform 0.25s, box-shadow 0.25s; cursor: pointer; overflow: hidden; }
    .tour-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
    .tour-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(42,26,14,0.12); }
    .tour-card:hover::before { transform: scaleX(1); }
    .tour-card.featured { background: var(--green); color: var(--white); grid-row: span 2; }
    .tour-card.featured::before { background: var(--gold); }
    .tour-img { width: calc(100% + 64px); margin: -36px -32px 24px; height: 180px; background-size: cover; background-position: center; flex-shrink: 0; position: relative; }
    .tour-card.featured .tour-img { height: 320px; }
    .tour-img::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.35) 100%); }
    .tour-type { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
    .tour-card.featured .tour-type { color: var(--gold-light); }
    .tour-title { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 600; color: var(--wine); margin-bottom: 8px; line-height: 1.2; }
    .tour-card.featured .tour-title { color: var(--white); }
    .tour-desc { color: var(--text-muted); font-size: 14px; line-height: 1.7; margin-bottom: 20px; flex: 1; }
    .tour-card.featured .tour-desc { color: rgba(255,255,255,0.7); }
    .tour-meta { display: flex; gap: 16px; margin-bottom: 24px; }
    .tour-meta-item { font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; }
    .tour-card.featured .tour-meta-item { color: rgba(255,255,255,0.6); }
    .tour-availability { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #5a9a5a; margin-top: 10px; }
    .avail-dot { width: 6px; height: 6px; background: #5a9a5a; border-radius: 50%; animation: pulse 2s infinite; }
    .tour-card.featured .tour-availability { color: #7dd87d; }
    .tour-card.featured .avail-dot { background: #7dd87d; }
    .tour-price-row { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--cream-dark); padding-top: 20px; margin-top: auto; }
    .tour-card.featured .tour-price-row { border-color: rgba(255,255,255,0.15); }
    .tour-price { font-family: 'Playfair Display', serif; }
    .tour-price span { font-size: 11px; color: var(--text-muted); display: block; margin-bottom: 2px; }
    .tour-card.featured .tour-price span { color: rgba(255,255,255,0.5); }
    .tour-price strong { font-size: 24px; color: var(--text); }
    .tour-card.featured .tour-price strong { color: var(--white); }
    .btn-tour { background: var(--green); color: var(--white); border: none; padding: 10px 18px; font-family: 'Lato', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; text-decoration: none; border-radius: 2px; transition: filter 0.2s; }
    .tour-card.featured .btn-tour { background: var(--gold); color: var(--text); }
    .btn-tour:hover { filter: brightness(1.1); }
    .testimonials-section { background: var(--wine); padding: 80px; }
    .testimonials-section .section-label { color: var(--gold-light); }
    .testimonials-section .section-title { color: var(--white); }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .testimonial-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 28px; }
    .testi-stars { color: var(--gold-light); font-size: 14px; letter-spacing: 2px; margin-bottom: 14px; }
    .testi-text { font-family: 'Playfair Display', serif; font-style: italic; font-size: 16px; color: rgba(255,255,255,0.9); line-height: 1.6; margin-bottom: 20px; }
    .testi-author { display: flex; align-items: center; gap: 10px; }
    .testi-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--cream-dark); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: var(--wine); flex-shrink: 0; }
    .testi-name { font-size: 13px; font-weight: 700; color: var(--white); }
    .testi-origin { font-size: 12px; color: rgba(255,255,255,0.45); }
    .testi-platform { font-size: 11px; color: var(--gold-light); letter-spacing: 0.08em; text-transform: uppercase; margin-left: auto; }
    .footer { background: var(--text); color: rgba(255,255,255,0.6); padding: 48px 80px; display: flex; justify-content: space-between; align-items: center; gap: 32px; flex-wrap: wrap; }
    .footer-brand { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--white); margin-bottom: 4px; }
    .footer-links { display: flex; gap: 24px; font-size: 12px; letter-spacing: 0.08em; }
    .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
    .footer-links a:hover { color: var(--gold-light); }
    .footer-contact { text-align: right; font-size: 14px; }
    .footer-contact a { color: var(--gold-light); text-decoration: none; font-weight: 700; display: block; margin-bottom: 4px; }
    .nav-hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px; color: var(--text); }
    .mobile-menu { display: none; position: fixed; top: 64px; left: 0; right: 0; background: rgba(244,239,227,0.97); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(196,150,58,0.2); padding: 20px 24px; z-index: 99; }
    .mobile-menu.open { display: block; }
    .mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .mobile-menu a { text-decoration: none; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }
    .mobile-menu-langs { display: flex; gap: 12px; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(196,150,58,0.2); }
    .mobile-menu-langs a { font-size: 13px; color: var(--text-muted); text-decoration: none; }
    .mobile-menu-langs a.active { color: var(--gold); }
    @media (max-width: 768px) {
      .nav { padding: 0 20px; }
      .nav-links, .nav-langs { display: none; }
      .nav-hamburger { display: block; }
      .nav-right .btn-primary { display: none; }
      .hero-content { padding: 0 24px 48px; grid-template-columns: 1fr; }
      .urgency-box { display: none; }
      section { padding: 48px 24px; }
      .trust-bar { padding: 14px 24px; flex-wrap: wrap; gap: 14px; }
      .guide-section { grid-template-columns: 1fr; }
      .guide-image { min-height: 280px; }
      .guide-text { padding: 40px 24px; }
      .guide-image-overlay { background: linear-gradient(to bottom, transparent 60%, var(--white)); }
      .tours-grid { grid-template-columns: 1fr; }
      .tour-card.featured { grid-row: span 1; }
      .testimonials-grid { grid-template-columns: 1fr; padding: 0; }
      .testimonials-section { padding: 48px 24px; }
      .footer { padding: 32px 24px; flex-direction: column; align-items: flex-start; }
      .footer-contact { text-align: left; }
    }
  </style>
</head>
<body>

<nav class="nav">
  <a href={`${base}fr/`} class="nav-logo">
    <img src={`${base}img/guia/logo%20sin%20fondo.png`} alt="El Escorial" height="36" style="height:36px; width:auto; display:block;" />
  </a>
  <ul class="nav-links">
    <li><a href={`${base}fr/el-escorial/`}>El Escorial</a></li>
    <li><a href={`${base}fr/avila/`}>Ávila</a></li>
    <li><a href={`${base}fr/segovia/`}>Ségovie</a></li>
    <li><a href={`${base}fr/cuelgamuros/`}>Cuelgamuros</a></li>
    <li><a href={`${base}fr/madrid/`}>Madrid</a></li>
    <li><a href={`${base}fr/a-propos/`}>À propos</a></li>
  </ul>
  <div class="nav-right">
    <div class="nav-langs">
      <a href={`${base}es/`}>ES</a>
      <a href={`${base}en/`}>EN</a>
      <a href={`${base}it/`}>IT</a>
      <a href={`${base}fr/`} class="active">FR</a>
      <a href={`${base}pt/`}>PT</a>
    </div>
    <a href={`https://wa.me/${wa}`} target="_blank" rel="noopener" class="btn-primary">Réserver</a>
  </div>
  <button class="nav-hamburger" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
</nav>

<div class="mobile-menu" id="mobile-menu" role="navigation" aria-label="Menu mobile">
  <ul>
    <li><a href={`${base}fr/el-escorial/`}>El Escorial</a></li>
    <li><a href={`${base}fr/avila/`}>Ávila</a></li>
    <li><a href={`${base}fr/segovia/`}>Ségovie</a></li>
    <li><a href={`${base}fr/cuelgamuros/`}>Cuelgamuros</a></li>
    <li><a href={`${base}fr/madrid/`}>Madrid</a></li>
    <li><a href={`${base}fr/a-propos/`}>À propos</a></li>
    <li><a href={`https://wa.me/${wa}`} target="_blank" rel="noopener" style="color: var(--green); font-weight: 700;">Réserver une visite</a></li>
  </ul>
  <div class="mobile-menu-langs">
    <a href={`${base}es/`}>ES</a>
    <a href={`${base}en/`}>EN</a>
    <a href={`${base}it/`}>IT</a>
    <a href={`${base}fr/`} class="active">FR</a>
    <a href={`${base}pt/`}>PT</a>
  </div>
</div>

<section class="hero">
  <div class="hero-bg" style={`background: linear-gradient(to top, rgba(10,8,18,0.92) 0%, rgba(10,8,18,0.45) 45%, rgba(10,8,18,0.15) 100%), url('${base}img/escorial/monasterio-noche.webp') center/cover no-repeat`}></div>
  <div class="hero-content">
    <div>
      <div class="hero-badge">Visites théâtralisées · Guide officielle du Patrimoine National</div>
      <h1>L'histoire qui vous atteint<br><em>par tous les sens</em></h1>
      <p class="hero-sub">Visites théâtralisées du Monastère de l'Escorial et des grands monuments de Castille. Philippe II comme vous ne l'avez jamais entendu.</p>
      <div class="hero-actions">
        <a href="#visites" class="btn-primary">Voir les visites disponibles</a>
        <a href="#guide" class="btn-ghost">Découvrir María Victoria</a>
      </div>
      <div class="hero-proof">
        <span class="stars">★★★★★</span>
        <span>+400 avis · 4,9/5 sur Google</span>
      </div>
    </div>
    <div class="urgency-box">
      <div class="urgency-label">Prochaine visite disponible</div>
      <div class="urgency-date">Samedi 26 avril</div>
      <div class="urgency-spots">
        <div class="spot-dots">
          <div class="dot taken"></div><div class="dot taken"></div><div class="dot taken"></div>
          <div class="dot taken"></div><div class="dot taken"></div><div class="dot taken"></div>
          <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <span>Plus que 4 places</span>
      </div>
      <a href={`https://wa.me/${wa}?text=Bonjour%20Mar%C3%ADa%20Victoria%2C%20je%20voudrais%20r%C3%A9server%20pour%20le%2026%20avril`} target="_blank" rel="noopener" class="btn-primary" style="width:100%; text-align:center;">Réserver maintenant →</a>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-item"><strong>+20 ans</strong> de guide officielle du Patrimoine</div>
  <div class="trust-divider"></div>
  <div class="trust-item"><strong>5 langues :</strong> ES · EN · IT · FR · PT</div>
  <div class="trust-divider"></div>
  <div class="trust-item"><strong>Petits groupes</strong> · max. 10 personnes</div>
  <div class="trust-divider"></div>
  <div class="trust-item"><strong>Annulation gratuite</strong> jusqu'à 48h avant</div>
</div>

<div class="guide-section" id="guide">
  <div class="guide-image" style={`background-image: url('${base}img/guia/Foto%20guia%20con%20perro%20mas%20graciosa%20con%20perro%20sonriendo.jpeg')`}>
    <div class="guide-image-overlay"></div>
  </div>
  <div class="guide-text">
    <div class="section-label">Votre guide</div>
    <h2 class="section-title">María Victoria Solaz</h2>
    <div class="guide-credentials">
      <span class="cred-tag">Guide officielle du Patrimoine National</span>
      <span class="cred-tag">5 langues</span>
      <span class="cred-tag">+20 ans d'expérience</span>
    </div>
