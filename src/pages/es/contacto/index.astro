---
import Base from '../../../layouts/Base.astro';
import { SITE } from '../../../data/i18n.js';
const lang = 'es';
---
<Base lang={lang} title="Contacto — Reserva tu visita" description="Contacta para reservar tu visita teatralizada al Escorial, Ávila, Segovia o Cuelgamuros." path="/contacto/">
  <article class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Contacto</h1>
    <div class="grid md:grid-cols-2 gap-8">
      <div>
        <h2 class="text-xl font-bold mb-4">WhatsApp (recomendado)</h2>
        <a href={`https://wa.me/${SITE.whatsapp.replace('+','')}`} target="_blank" rel="noopener" class="inline-block btn-whatsapp px-8 py-3 rounded-lg text-lg font-medium">💬 Abrir WhatsApp</a>
      </div>
      <div>
        <h2 class="text-xl font-bold mb-4">Formulario</h2>
        <form action="https://formspree.io/f/FORMSPREE_ID" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-sepia mb-1">Nombre</label>
            <input id="name" type="text" name="name" placeholder="Tu nombre" required class="w-full border border-gray-300 rounded px-4 py-2" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-sepia mb-1">Email</label>
            <input id="email" type="email" name="email" placeholder="tu@email.com" required class="w-full border border-gray-300 rounded px-4 py-2" />
          </div>
          <fieldset>
            <legend class="block text-sm font-medium text-sepia mb-2">Destinos (puedes elegir varios)</legend>
            <div class="space-y-2">
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="escorial" class="rounded" /> Monasterio de El Escorial</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="avila" class="rounded" /> Ávila</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="segovia" class="rounded" /> Segovia</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="cuelgamuros" class="rounded" /> Cuelgamuros</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-austrias" class="rounded" /> Madrid de los Austrias</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-borbones" class="rounded" /> Madrid de los Borbones</label>
              <label class="flex items-center gap-2"><input type="checkbox" name="destinations[]" value="madrid-tour" class="rounded" /> Madrid — Tour personalizado</label>
            </div>
          </fieldset>
          <div>
            <label for="message" class="block text-sm font-medium text-sepia mb-1">Mensaje</label>
            <textarea id="message" name="message" placeholder="Tu mensaje" rows="4" class="w-full border border-gray-300 rounded px-4 py-2"></textarea>
          </div>
          <button type="submit" class="btn-primary px-6 py-2 rounded">Enviar</button>
        </form>
      </div>
    </div>
  </article>
</Base>
