---
import Base from '../../../layouts/Base.astro';
import { SITE, t } from '../../../data/i18n.js';

const lang = 'en';
const base = import.meta.env.BASE_URL;
const ui = t(lang);
const dest = ui.destinations.madrid;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Madrid histórico",
  "alternateName": ["Madrid de los Austrias", "Madrid de los Borbones"],
  "sameAs": ["https://www.wikidata.org/wiki/Q2807"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Madrid",
    "addressCountry": "ES"
  },
  "about": [
    { "@type": "Thing", "name": "Casa de Austria" },
    { "@type": "Thing", "name": "Casa de Borbón" },
    { "@type": "Thing", "name": "Museo del Prado" },
    { "@type": "Thing", "name": "Palacio Real de Madrid" }
  ]
};
---

<Base lang={lang} title="Madrid — Custom tours from the Habsburgs to the Bourbons" description="Custom tours of Habsburg and Bourbon Madrid. Museums, palaces and monuments with María Victoria Solaz, certified National Heritage Guide." jsonLd={jsonLd} path="/madrid/">

  <div class="w-full h-64 md:h-96 overflow-hidden">
    <img src={`${base}img/madrid/cibeles-atardecer.webp`} alt="Madrid Cibeles at sunset" class="w-full h-full object-cover" width="612" height="408" loading="eager" />
  </div>

  <article class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">{dest.name}</h1>
    <p class="text-xl text-sepia mb-8">{dest.tagline}</p>

    <section class="prose prose-lg max-w-none mb-12">
      <h2>Two Madrids in one city</h2>
      <p>
        Madrid has two historical souls. Habsburg Madrid — Philip II's Madrid, the Plaza Mayor, baroque churches and alleyways hiding centuries of court intrigue. And Bourbon Madrid — the Royal Palace, the Prado, the Retiro and the reinvention of a capital that wanted to rival Paris and Vienna.
      </p>
      <p>
        María Victoria knows both like her own home. What makes her different is that she doesn't describe Madrid like a museum — she tells it like a story that connects every street, every square and every painting with the people who created them.
      </p>
      <div class="my-6">
        <img src={`${base}img/guia/PLAZA%20MAYOR%20MADRID%20ESTATUA.jpeg`} alt="Equestrian statue of Philip III in the Plaza Mayor, Madrid" class="rounded-lg w-full" loading="lazy" />
        <p class="text-sm text-sepia/70 mt-2 text-center italic">Philip III presides over the Plaza Mayor — heart of Habsburg Madrid since 1619</p>
      </div>

      <h2>A tour made for you</h2>
      <p>
        No two tours are alike. Depending on your time, interests and curiosity, María Victoria designs a personalised itinerary. Prado in the morning and Habsburg Madrid in the afternoon? Done. A thematic tour of Philip II's court? Also possible. Visiting with children who can't afford to be bored? She has decades of school groups — she knows exactly how to keep them engaged.
      </p>

      <h2>Museums, palaces and more</h2>
      <p>
        Prado Museum, Reina Sofía, Royal Palace, Almudena Cathedral, Plaza Mayor, Puerta del Sol, Retiro, Temple of Debod — and any corner that interests you. María Victoria also organises visits to the Santiago Bernabéu combined with Madrid's museums. Because a city's history doesn't have to be solemn — sometimes it happens in a stadium too.
      </p>
    </section>

    <!-- SUB-ROUTES -->
    <section class="grid md:grid-cols-2 gap-6 mb-12">
      <a href={`${base}en/madrid/habsburgs/`} class="card-hover rounded-lg p-6 border block">
        <h2 class="text-xl font-bold mb-2">Habsburg Madrid</h2>
        <p class="text-sepia">Philip II's imperial capital. Plaza Mayor, Literary Quarter, secret passages, Casas a la Malicia and the Spanish Golden Age.</p>
      </a>
      <a href={`${base}en/madrid/bourbons/`} class="card-hover rounded-lg p-6 border block">
        <h2 class="text-xl font-bold mb-2">Bourbon Madrid</h2>
        <p class="text-sepia">Enlightened Madrid. Royal Palace, Prado, Retiro, Gran Vía and the neoclassical reinvention of a capital that dared rival Paris.</p>
      </a>
    </section>

    <div class="cta-box rounded-lg p-8 text-center">
      <h2 class="text-2xl font-bold mb-2">{dest.productName}</h2>
      <p class="text-sepia mb-4">Tell María Victoria what you'd like to see and she'll design your itinerary</p>
      <a
        href={`${base}${lang}/madrid/${dest.productSlug}/`}
        class="inline-block btn-whatsapp px-8 py-3 rounded-lg font-medium"
      >
        Details & booking →
      </a>
    </div>
  </article>

</Base>
